{
    "name": "diegobvasco/laravel-actions",
    "description": "This is my package laravel-actions",
    "keywords": [
        "Diego Vasconcelos",
        "laravel",
        "laravel-actions"
    ],
    "homepage": "https://github.com/diegobvasco/laravel-actions",
    "license": "MIT",
    "authors": [
        {
            "name": "Diego Vasconcelos",
            "email": "diego_vasconcelos1@hotmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "DiegoVasconcelos\\Actions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DiegoVasconcelos\\Actions\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "lint": [
            "vendor/bin/pint",
            "rector"
        ],
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:unit": "XDEBUG_MODE=coverage pest --parallel --coverage --exactly=100",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:types": "phpstan",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DiegoVasconcelos\\Actions\\ActionsServiceProvider"
            ],
            "aliases": {
                "Actions": "DiegoVasconcelos\\Actions\\Facades\\Actions"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
